prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_memory
Description: Abseil memory library
URL: https://abseil.io/
Version: 20260107
Requires: absl_core_headers = 20260107, absl_meta = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

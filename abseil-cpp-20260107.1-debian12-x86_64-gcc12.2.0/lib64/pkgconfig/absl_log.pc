prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_log
Description: Abseil log library
URL: https://abseil.io/
Version: 20260107
Requires: absl_log_internal_log_impl = 20260107, absl_vlog_is_on = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

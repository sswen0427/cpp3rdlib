prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_heterogeneous_lookup_testing
Description: Abseil heterogeneous_lookup_testing library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_test_instance_tracker = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX -Wno-deprecated-declarations -Wno-missing-declarations -Wno-self-move -Wno-sign-compare -Wno-unused-function -Wno-unused-parameter -Wno-unused-private-field

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_raw_hash_map
Description: Abseil raw_hash_map library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_common_policy_traits = 20260107, absl_container_memory = 20260107, absl_core_headers = 20260107, absl_raw_hash_set = 20260107, absl_type_traits = 20260107, absl_throw_delegate = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

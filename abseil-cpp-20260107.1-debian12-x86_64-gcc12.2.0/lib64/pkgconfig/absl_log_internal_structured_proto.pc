prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_log_internal_structured_proto
Description: Abseil log_internal_structured_proto library
URL: https://abseil.io/
Version: 20260107
Requires: absl_log_internal_proto = 20260107, absl_config = 20260107, absl_span = 20260107, absl_strings = 20260107, absl_variant = 20260107
Libs: -L${libdir}  -labsl_log_internal_structured_proto 
Cflags: -I${includedir} -DNOMINMAX

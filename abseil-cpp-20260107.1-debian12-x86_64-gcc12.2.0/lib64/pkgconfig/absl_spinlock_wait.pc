prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_spinlock_wait
Description: Abseil spinlock_wait library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base_internal = 20260107, absl_core_headers = 20260107, absl_errno_saver = 20260107
Libs: -L${libdir}  -labsl_spinlock_wait 
Cflags: -I${includedir} -DNOMINMAX

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_inlined_vector_internal
Description: Abseil inlined_vector_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base_internal = 20260107, absl_compressed_tuple = 20260107, absl_config = 20260107, absl_core_headers = 20260107, absl_memory = 20260107, absl_span = 20260107, absl_type_traits = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

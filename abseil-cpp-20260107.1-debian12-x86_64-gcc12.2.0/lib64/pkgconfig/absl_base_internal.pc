prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_base_internal
Description: Abseil base_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_type_traits = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

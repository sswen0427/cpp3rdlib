prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_debugging_internal
Description: Abseil debugging_internal library
URL: https://abseil.io/
Version: 20260107
Requires: absl_core_headers = 20260107, absl_config = 20260107, absl_dynamic_annotations = 20260107, absl_errno_saver = 20260107, absl_raw_logging_internal = 20260107
Libs: -L${libdir}  -labsl_debugging_internal 
Cflags: -I${includedir} -DNOMINMAX

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_city
Description: Abseil city library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_core_headers = 20260107, absl_endian = 20260107
Libs: -L${libdir}  -labsl_city 
Cflags: -I${includedir} -DNOMINMAX

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_periodic_sampler
Description: Abseil periodic_sampler library
URL: https://abseil.io/
Version: 20260107
Requires: absl_core_headers = 20260107, absl_exponential_biased = 20260107
Libs: -L${libdir}  -labsl_periodic_sampler 
Cflags: -I${includedir} -DNOMINMAX

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_sample_recorder
Description: Abseil sample_recorder library
URL: https://abseil.io/
Version: 20260107
Requires: absl_base = 20260107, absl_synchronization = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

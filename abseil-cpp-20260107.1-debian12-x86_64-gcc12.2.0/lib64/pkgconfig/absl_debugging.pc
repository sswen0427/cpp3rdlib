prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_debugging
Description: Abseil debugging library
URL: https://abseil.io/
Version: 20260107
Requires: absl_stacktrace = 20260107, absl_leak_check = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

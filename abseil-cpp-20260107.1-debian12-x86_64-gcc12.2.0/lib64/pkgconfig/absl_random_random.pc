prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_random_random
Description: Abseil random_random library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_random_distributions = 20260107, absl_random_internal_nonsecure_base = 20260107, absl_random_internal_pcg_engine = 20260107, absl_random_internal_randen_engine = 20260107, absl_random_seed_sequences = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

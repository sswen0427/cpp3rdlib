prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_random_internal_distribution_caller
Description: Abseil random_internal_distribution_caller library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_utility = 20260107, absl_fast_type_id = 20260107, absl_type_traits = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

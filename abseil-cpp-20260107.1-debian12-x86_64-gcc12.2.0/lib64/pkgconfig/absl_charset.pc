prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_charset
Description: Abseil charset library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_string_view = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${prefix}/lib64
includedir=${prefix}/include

Name: absl_log_internal_container
Description: Abseil log_internal_container library
URL: https://abseil.io/
Version: 20260107
Requires: absl_config = 20260107, absl_requires_internal = 20260107, absl_strings = 20260107
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX
